{
  "name": "cc-sanitizer",
  "version": "0.1.4",
  "description": "Clean thinking blocks from Claude Code sessions to fix cross-model compatibility",
  "type": "module",
  "bin": {
    "cc-sanitizer": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "tsx --test test/*.test.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "claude-code",
    "sanitizer",
    "thinking-blocks",
    "session-cleanup"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
